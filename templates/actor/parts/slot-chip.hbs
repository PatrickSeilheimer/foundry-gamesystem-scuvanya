{{#with this as |root|}}
<a class="slot-tile {{#if root.slot.item}}slot-tile--filled{{/if}}" data-action="openSlot" data-slot="{{root.slot.key}}" title="{{root.slot.label}}" {{#if root.slot.item}}data-item-tooltip="hover"{{/if}}>
  {{#if root.slot.item}}
  <div class="slot-tile__plate">
    <img class="slot-tile__img" src="{{root.slot.item.img}}">
    <span class="slot-tile__name">{{root.slot.item.name}}</span>
  </div>
  <div class="tooltip-content" hidden>
    {{> "systems/scuvanya/templates/actor/parts/item-tooltip.hbs" item=root.slot.item}}
  </div>
  {{else}}
  <svg class="slot-tile__placeholder" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
    {{#if (eq root.slot.iconKey "kopf")}}
    <path d="M4 15a8 8 0 0 1 16 0"/>
    <rect x="4" y="15" width="16" height="4" rx="1.5"/>
    {{else if (eq root.slot.iconKey "brust")}}
    <path d="M12 3l6 2.5v4.5c0 5.5-2.5 9-6 11-3.5-2-6-5.5-6-11V5.5z"/>
    {{else if (eq root.slot.iconKey "arme")}}
    <path d="M9 3v5a3 3 0 0 0 6 0V3"/>
    <rect x="8" y="8" width="8" height="10" rx="2.5"/>
    {{else if (eq root.slot.iconKey "beine")}}
    <path d="M7 3h10l0.8 7.5-1.6 10.5h-2.7l-1-9.5-1 9.5h-2.7l-1.6-10.5z"/>
    {{else if (eq root.slot.iconKey "fuesse")}}
    <path d="M10 3v10.5l-1.2 2H6a3 3 0 0 0-3 3V20h14v-3l-2.4-1.8V3z"/>
    {{else if (eq root.slot.iconKey "ohrringe")}}
    <path d="M12 4a3 3 0 0 1 3 3c0 2.3-3 8-3 8s-3-5.7-3-8a3 3 0 0 1 3-3z"/>
    {{else if (eq root.slot.iconKey "halskette")}}
    <path d="M6 4c1.8 4.5 3.6 6.5 6 6.5S16.2 8.5 18 4"/>
    <circle cx="12" cy="15" r="3.3"/>
    {{else if (eq root.slot.iconKey "armbaender")}}
    <ellipse cx="12" cy="12" rx="8" ry="5.2"/>
    <ellipse cx="12" cy="12" rx="5" ry="2.6"/>
    {{else if (eq root.slot.iconKey "ring")}}
    <path d="M9 8.5L12 4l3 4.5-3 2.2z"/>
    <ellipse cx="12" cy="15" rx="5" ry="3"/>
    {{else if (eq root.slot.iconKey "hauptHand")}}
    <line x1="12" y1="2" x2="12" y2="15"/>
    <line x1="7.5" y1="6.5" x2="16.5" y2="6.5"/>
    <path d="M9.3 15h5.4l-0.9 4h-3.6z"/>
    {{else if (eq root.slot.iconKey "nebenHand")}}
    <path d="M12 2 L19 4.5 V10.5 C19 15.5 16 19 12 21 C8 19 5 15.5 5 10.5 V4.5 Z"/>
    {{/if}}
  </svg>
  {{/if}}
</a>
{{/with}}
