{{#with this as |root|}}
<a class="slot-tile {{#if root.slot.item}}slot-tile--filled{{/if}}" data-action="openSlot" data-slot="{{root.slot.key}}" title="{{root.slot.label}}">
  {{#if root.slot.item}}
  <img class="slot-tile__img" src="{{root.slot.item.img}}">
  <span class="slot-tile__name">{{root.slot.item.name}}</span>
  {{else}}
  <svg class="slot-tile__placeholder" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round">
    {{#if (eq root.slot.iconKey "kopf")}}
    <path d="M4 15c0-6 3.5-10 8-10s8 4 8 10"/>
    <path d="M3 15h18v1.5a2.5 2.5 0 0 1-2.5 2.5h-13A2.5 2.5 0 0 1 3 16.5Z"/>
    <path d="M11 12v3"/>
    {{else if (eq root.slot.iconKey "brust")}}
    <path d="M7 4l5-2 5 2v6c0 6-2 10-5 12-3-2-5-6-5-12z"/>
    <line x1="12" y1="4" x2="12" y2="20"/>
    {{else if (eq root.slot.iconKey "arme")}}
    <path d="M8 3v7a4 4 0 0 0 4 4a4 4 0 0 0 4-4V6"/>
    <path d="M8 10h8v6a4 4 0 0 1-4 4a4 4 0 0 1-4-4z"/>
    {{else if (eq root.slot.iconKey "beine")}}
    <path d="M8 3h3v10l-1 8H7l-1-8z"/>
    <path d="M13 3h3v10l1 8h-3l-1-8z"/>
    {{else if (eq root.slot.iconKey "fuesse")}}
    <path d="M9 3v10l-1 3H6a3 3 0 0 0-3 3v1h11v-3l-2-1V3z"/>
    {{else if (eq root.slot.iconKey "ohrringe")}}
    <circle cx="12" cy="7" r="2.5"/>
    <path d="M12 9.5v4"/>
    <path d="M9.5 16a2.5 2.5 0 1 0 5 0"/>
    {{else if (eq root.slot.iconKey "halskette")}}
    <path d="M5 4c3 4 4 6 7 6s4-2 7-6"/>
    <circle cx="12" cy="15" r="3.5"/>
    {{else if (eq root.slot.iconKey "armbaender")}}
    <ellipse cx="12" cy="12" rx="7" ry="4"/>
    <ellipse cx="12" cy="12" rx="4" ry="2"/>
    {{else if (eq root.slot.iconKey "ring")}}
    <circle cx="12" cy="14" r="6"/>
    <path d="M9 8l3-4 3 4z"/>
    {{else if (eq root.slot.iconKey "hauptHand")}}
    <line x1="12" y1="2" x2="12" y2="16"/>
    <line x1="8" y1="6" x2="16" y2="6"/>
    <path d="M9 16h6l-1 3h-4z"/>
    <line x1="12" y1="19" x2="12" y2="22"/>
    {{else if (eq root.slot.iconKey "nebenHand")}}
    <path d="M12 2 L20 5 V11 C20 16 16.5 20 12 22 C7.5 20 4 16 4 11 V5 Z"/>
    {{/if}}
  </svg>
  {{/if}}
</a>
{{/with}}
