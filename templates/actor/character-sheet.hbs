<form class="scuvanya-sheet character-sheet" autocomplete="off">

  <div class="sheet-topbar">
    <img class="sheet-topbar__portrait" src="{{actor.img}}" data-action="editImage" data-edit="img" title="{{actor.name}}">
    <input class="sheet-topbar__name" name="name" type="text" value="{{actor.name}}" placeholder="{{localize 'SCUVANYA.Name'}}">

    <div class="sheet-res sheet-res--lp" title="{{localize 'SCUVANYA.Resource.hp'}}">
      <svg class="sheet-res__icon" viewBox="0 0 24 24" fill="currentColor" stroke="none"><path d="M12 21s-7.5-4.6-10-9.5C0.5 7.8 2.6 4 6.5 4 9 4 11 5.8 12 8c1-2.2 3-4 5.5-4 3.9 0 6 3.8 4.5 7.5C19.5 16.4 12 21 12 21Z"/></svg>
      <span class="sheet-res__label">{{localize 'SCUVANYA.Resource.hp'}}</span>
      <div class="sheet-res__bar"><div class="sheet-res__fill sheet-res__fill--lp" style="width: {{percent system.resources.hp.value system.resources.hp.max}}%"></div></div>
      <span class="sheet-res__value">
        <input type="number" name="system.resources.hp.value" value="{{system.resources.hp.value}}"> / {{system.resources.hp.max}}
      </span>
    </div>

    <div class="sheet-res sheet-res--mana" title="{{localize 'SCUVANYA.Resource.mana'}}">
      <svg class="sheet-res__icon" viewBox="0 0 24 24" fill="currentColor" stroke="none"><path d="M12 2C12 2 5 11 5 15.5A7 7 0 0 0 19 15.5C19 11 12 2 12 2Z"/></svg>
      <span class="sheet-res__label">{{localize 'SCUVANYA.Resource.mana'}}</span>
      <div class="sheet-res__bar"><div class="sheet-res__fill sheet-res__fill--mana" style="width: {{percent system.resources.mana.value system.resources.mana.max}}%"></div></div>
      <span class="sheet-res__value">
        <input type="number" name="system.resources.mana.value" value="{{system.resources.mana.value}}"> / {{system.resources.mana.max}}
      </span>
    </div>

    <div class="sheet-res sheet-res--mg" title="{{localize 'SCUVANYA.Resource.mentalHealth'}}">
      <svg class="sheet-res__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="9"/>
        <path d="M7 9c1.2-1 2-1 3 0s1.8 1 3 0 2-1 3 0"/>
        <path d="M7 12.5c1.2-1 2-1 3 0s1.8 1 3 0 2-1 3 0"/>
        <path d="M7 16c1.2-1 2-1 3 0s1.8 1 3 0 2-1 3 0"/>
      </svg>
      <span class="sheet-res__label">{{localize 'SCUVANYA.Resource.mentalHealth'}}</span>
      <div class="sheet-res__bar"><div class="sheet-res__fill sheet-res__fill--mg" style="width: {{percent system.resources.mentalHealth.value system.resources.mentalHealth.max}}%"></div></div>
      <span class="sheet-res__value">
        <input type="number" name="system.resources.mentalHealth.value" value="{{system.resources.mentalHealth.value}}"> / {{system.resources.mentalHealth.max}}
      </span>
    </div>

    <div class="sheet-topbar__spacer"></div>
    <button type="button" class="cc-btn cc-btn--primary" data-action="openCreationWizard">{{localize 'SCUVANYA.Wizard.OpenButton'}}</button>
  </div>

  <div class="sheet-folder">
    <div class="sheet-folder__paper sheet-body">

      {{!-- UEBERSICHT --}}
      <div class="tab uebersicht-tab {{#if (eq activeTab 'attribute')}}active{{/if}}">
        <h1 class="sheet-title">{{actor.name}}</h1>
        <div class="sheet-subline">
          {{#if items.race}}<span>{{items.race.name}}</span>{{/if}}
          {{#if items.profession}}<span>{{items.profession.name}}</span>{{/if}}
          <span>{{localize (concat "SCUVANYA.Body." system.geschlecht)}}</span>
          {{#if body.age}}<span>{{body.age}} {{localize 'SCUVANYA.Body.age'}}</span>{{/if}}
          {{#if body.height}}<span>{{body.height}} m</span>{{/if}}
          {{#if body.weight}}<span>{{body.weight}} kg</span>{{/if}}
        </div>

        <section class="sheet-section">
          <h2 class="cc-section__title">{{localize 'SCUVANYA.Section.attribute'}}</h2>
          <div class="uebersicht-attribute">
            {{#each attributes as |attr|}}
            <div class="uebersicht-attribut">
              {{#if attr.raceBonus}}<span class="uebersicht-attribut__dot" title="{{localize 'SCUVANYA.Hint.RaceBonusIncluded'}}"></span>{{/if}}
              <a class="uebersicht-attribut__roll" data-action="rollAttribute" data-key="{{attr.key}}" title="{{localize 'SCUVANYA.Roll'}}">🎲</a>
              <span class="uebersicht-attribut__abk">{{attr.abbr}}</span>
              <span class="uebersicht-attribut__buy">
                <a data-action="buyAttribute" data-key="{{attr.key}}" data-delta="-1">−</a>
                <span class="uebersicht-attribut__wert">{{attr.effectiveValue}}</span>
                <a data-action="buyAttribute" data-key="{{attr.key}}" data-delta="1" title="{{localize 'SCUVANYA.SkillPoints.CostHint'}}: {{attr.nextCost}}">+</a>
              </span>
              <span class="uebersicht-attribut__mod">{{attr.modDisplay}}</span>
            </div>
            {{/each}}
          </div>
        </section>

        <section class="sheet-section">
          <h2 class="cc-section__title">{{localize 'SCUVANYA.Section.kampfMagie'}}</h2>
          <div class="uebersicht-disziplinen">
            {{#each kampfDisziplinen as |d|}}
            <div class="uebersicht-disziplin">
              {{#if d.img}}<img class="uebersicht-disziplin__img" src="{{d.img}}">{{/if}}
              <span class="uebersicht-disziplin__name">{{d.label}}</span>
              <div class="uebersicht-disziplin__bar"><div class="uebersicht-disziplin__fill" style="width: {{d.widthPercent}}%"></div></div>
              <span class="uebersicht-disziplin__stufe">{{d.level}}/10</span>
            </div>
            {{/each}}
            {{#each magieDisziplinen as |d|}}
            <div class="uebersicht-disziplin">
              {{#if d.img}}<img class="uebersicht-disziplin__img" src="{{d.img}}">{{/if}}
              <span class="uebersicht-disziplin__name">{{d.label}}</span>
              <div class="uebersicht-disziplin__bar"><div class="uebersicht-disziplin__fill" style="width: {{d.widthPercent}}%"></div></div>
              <span class="uebersicht-disziplin__stufe">{{d.level}}/10</span>
            </div>
            {{/each}}
          </div>
        </section>

        {{#if weitereSprachen.length}}
        <section class="sheet-section">
          <h2 class="cc-section__title">{{localize 'SCUVANYA.Section.sprachenBekannt'}}</h2>
          <div class="cc-chip-row">
            <span class="cc-chip">{{localize 'SCUVANYA.Language.Gemeinsprache'}} · {{gemeinsprache.level}}</span>
            {{#each weitereSprachen as |sprache|}}
            <span class="cc-chip">{{sprache.name}} · {{sprache.level}}</span>
            {{/each}}
          </div>
        </section>
        {{/if}}

        <section class="sheet-section">
          <h2 class="cc-section__title">{{localize 'SCUVANYA.Section.ruestungResistenz'}}</h2>
          <div class="uebersicht-stats">
            <div class="uebersicht-stat">
              <span>{{localize 'SCUVANYA.Armor.physical'}}</span>
              <span class="uebersicht-stat__wert">
                <input type="number" name="system.armor.physical" value="{{system.armor.physical}}">{{#if (ne system.armorEffective.physical system.armor.physical)}} ({{system.armorEffective.physical}}){{/if}}
              </span>
            </div>
            <div class="uebersicht-stat">
              <span>{{localize 'SCUVANYA.Armor.magical'}}</span>
              <span class="uebersicht-stat__wert">
                <input type="number" name="system.armor.magical" value="{{system.armor.magical}}">{{#if (ne system.armorEffective.magical system.armor.magical)}} ({{system.armorEffective.magical}}){{/if}}
              </span>
            </div>
            <div class="uebersicht-stat">
              <span>{{localize 'SCUVANYA.AC'}}</span>
              <span class="uebersicht-stat__wert">
                <input type="number" name="system.ac.value" value="{{system.ac.value}}">{{#if (ne system.acEffective system.ac.value)}} ({{system.acEffective}}){{/if}}
              </span>
            </div>
          </div>

          {{#if resistanceChips.length}}
          <div class="cc-chip-row uebersicht-resistenzen">
            {{#each resistanceChips as |chip|}}
            <span class="cc-chip uebersicht-resistenz-chip uebersicht-resistenz-chip--{{chip.typ}}">{{chip.name}}: {{chip.label}}</span>
            {{/each}}
          </div>
          {{else}}
          <p class="uebersicht-resistenzen-leer">{{localize 'SCUVANYA.Resistance.none'}}</p>
          {{/if}}
        </section>

        <section class="sheet-section">
          <h2 class="cc-section__title">{{localize 'SCUVANYA.Section.sonstigeWerte'}}</h2>
          <div class="uebersicht-stats">
            <div class="uebersicht-stat">
              <span>{{localize 'SCUVANYA.SkillPoints.total'}}</span>
              <span class="uebersicht-stat__wert"><input type="number" min="0" name="system.skillPoints.total" value="{{skillPoints.total}}"></span>
            </div>
            <div class="uebersicht-stat">
              <span>{{localize 'SCUVANYA.SkillPoints.available'}}</span>
              <span class="uebersicht-stat__wert {{#if (lt skillPoints.available 0)}}negative{{/if}}">{{skillPoints.available}} / {{skillPoints.spent}}</span>
            </div>
          </div>
        </section>
      </div>

      {{!-- TALENTE --}}
      <div class="tab talente-tab {{#if (eq activeTab 'talente')}}active{{/if}}">
        <h1 class="sheet-title">{{localize 'SCUVANYA.Tab.talente'}}</h1>
        <p class="sheet-hint">{{localize 'SCUVANYA.Roll'}}: {{localize 'SCUVANYA.Name'}} anklicken.</p>

        <div class="talente-liste">
          <div class="cc-category-pair">
            {{> "systems/scuvanya/templates/actor/parts/skill-category.hbs" title=(localize 'SCUVANYA.Category.sozialPositiv') system=(localize 'SCUVANYA.System.wurf') skills=sozialPositiv rollAction="rollSocialSkill" rollDataName="polarity" rollDataValue="positiv" buyPrefix="talents.sozial.positiv"}}
            {{> "systems/scuvanya/templates/actor/parts/skill-category.hbs" title=(localize 'SCUVANYA.Category.sozialNegativ') system=(localize 'SCUVANYA.System.wurf') skills=sozialNegativ rollAction="rollSocialSkill" rollDataName="polarity" rollDataValue="negativ" buyPrefix="talents.sozial.negativ"}}
          </div>
          <div class="cc-category-pair">
            {{> "systems/scuvanya/templates/actor/parts/skill-category.hbs" title=(localize 'SCUVANYA.Category.wissenschaftenSozial') system=(localize 'SCUVANYA.System.wurf') skills=wissenschaftenSozial rollAction="rollScienceSkill" rollDataName="branch" rollDataValue="sozial" buyPrefix="talents.wissenschaften.sozial"}}
            {{> "systems/scuvanya/templates/actor/parts/skill-category.hbs" title=(localize 'SCUVANYA.Category.wissenschaftenNatur') system=(localize 'SCUVANYA.System.wurf') skills=wissenschaftenNatur rollAction="rollScienceSkill" rollDataName="branch" rollDataValue="natur" buyPrefix="talents.wissenschaften.natur"}}
          </div>
          <div class="cc-category-pair">
            {{> "systems/scuvanya/templates/actor/parts/skill-category.hbs" title=(localize 'SCUVANYA.Category.koerperlich') system=(localize 'SCUVANYA.System.wurf') skills=koerperlich rollAction="rollPhysicalSkill" buyPrefix="talents.koerperlich" showBonus=true}}
            {{> "systems/scuvanya/templates/actor/parts/skill-category.hbs" title=(localize 'SCUVANYA.Category.sonder') system=(localize 'SCUVANYA.System.wurf') skills=sonder rollAction="rollSonderSkill" buyPrefix="talents.sonder"}}
          </div>
          <div class="cc-category-pair">
            {{> "systems/scuvanya/templates/actor/parts/tiered-category.hbs" title=(localize 'SCUVANYA.Category.handwerk') skills=handwerk rollAction="rollHandwerkSkill" buyCategory="handwerk" buyPrefix="talents.handwerk"}}
            {{> "systems/scuvanya/templates/actor/parts/tiered-category.hbs" title=(localize 'SCUVANYA.Category.spezial') skills=spezial rollAction="rollSpezialSkill" buyCategory="spezial" buyPrefix="talents.spezial"}}
          </div>

          <div class="cc-category-pair cc-category-pair--single">
            <div class="cc-category">
              <div class="cc-category__header">
                <span>{{localize 'SCUVANYA.Category.extra'}}</span>
              </div>
              <div class="cc-category__body">
                {{#each extra as |skill|}}
                <div class="talent-row talent-row--extra">
                  <span class="talent-row__name">{{skill.label}}</span>
                  {{#if skill.granted}}
                  <span class="talent-row__stat" title="{{localize 'SCUVANYA.Hint.GrantedByProgression'}}">✓</span>
                  {{else}}
                  <a class="extra-toggle {{#if skill.known}}active{{/if}}" data-action="buyExtra" data-key="{{skill.key}}">
                    {{#if skill.known}}✓{{else}}—{{/if}}
                  </a>
                  <span class="cost-hint">{{#unless skill.known}}({{skill.cost}}){{/unless}}</span>
                  {{/if}}
                </div>
                {{/each}}
              </div>
            </div>
          </div>
        </div>
      </div>

      {{!-- KAMPF & MAGIE --}}
      <div class="tab kampf-tab {{#if (eq activeTab 'kampf')}}active{{/if}}">
        <h1 class="sheet-title">{{localize 'SCUVANYA.Tab.kampf'}}</h1>

        <section class="sheet-section">
          <h2 class="cc-section__title">{{localize 'SCUVANYA.Category.kampfdisziplinen'}}</h2>
          <div class="disziplin-liste">
            {{#each kampfDisziplinen as |d|}}
            <div class="disziplin-card">
              {{#if d.img}}<img class="disziplin-card__img" src="{{d.img}}">{{/if}}
              <div class="disziplin-card__body">
                <span class="disziplin-card__name">{{d.label}}</span>
                <div class="disziplin-card__bar"><div class="disziplin-card__fill" style="width: {{d.widthPercent}}%"></div></div>
              </div>
              <div class="disziplin-card__buy">
                <a data-action="buyTiered" data-category="disziplin" data-path="disziplinen.kampf.{{d.key}}.level" data-delta="-1">−</a>
                <span>{{d.level}}{{#if d.raceBonus}} (+{{d.raceBonus}}){{/if}}</span>
                <a data-action="buyTiered" data-category="disziplin" data-path="disziplinen.kampf.{{d.key}}.level" data-delta="1" title="{{localize 'SCUVANYA.SkillPoints.CostHint'}}: {{d.nextCost}}">+</a>
              </div>
              <a class="disziplin-card__roll" data-action="rollDiscipline" data-kind="kampf" data-key="{{d.key}}" title="{{localize 'SCUVANYA.Roll'}}">🎲</a>
            </div>
            {{/each}}
          </div>
        </section>

        <section class="sheet-section">
          <h2 class="cc-section__title">{{localize 'SCUVANYA.Category.magiedisziplinen'}}</h2>
          <div class="disziplin-liste">
            {{#each magieDisziplinen as |d|}}
            <div class="disziplin-card">
              {{#if d.img}}<img class="disziplin-card__img" src="{{d.img}}">{{/if}}
              <div class="disziplin-card__body">
                <span class="disziplin-card__name">{{d.label}}</span>
                <div class="disziplin-card__bar"><div class="disziplin-card__fill" style="width: {{d.widthPercent}}%"></div></div>
              </div>
              <div class="disziplin-card__buy">
                <a data-action="buyTiered" data-category="disziplin" data-path="disziplinen.magie.{{d.key}}.level" data-delta="-1">−</a>
                <span>{{d.level}}{{#if d.raceBonus}} (+{{d.raceBonus}}){{/if}}</span>
                <a data-action="buyTiered" data-category="disziplin" data-path="disziplinen.magie.{{d.key}}.level" data-delta="1" title="{{localize 'SCUVANYA.SkillPoints.CostHint'}}: {{d.nextCost}}">+</a>
              </div>
              <a class="disziplin-card__roll" data-action="rollDiscipline" data-kind="magie" data-key="{{d.key}}" title="{{localize 'SCUVANYA.Roll'}}">🎲</a>
            </div>
            {{/each}}
          </div>
        </section>
      </div>

      {{!-- SPRACHEN --}}
      <div class="tab sprachen-tab {{#if (eq activeTab 'sprachen')}}active{{/if}}">
        <h1 class="sheet-title">{{localize 'SCUVANYA.Tab.sprachen'}}</h1>
        <div class="ausr-liste">
          <div class="ausr-row">
            <span class="ausr-row__name">{{localize 'SCUVANYA.Language.Gemeinsprache'}}</span>
            <span class="flag-badge">{{gemeinsprache.level}}</span>
          </div>
          {{#each weitereSprachen as |sprache index|}}
          <div class="ausr-row" data-index="{{index}}">
            <input class="ausr-row__name-input" type="text" name="system.sprachen.weitere.{{index}}.name" value="{{sprache.name}}">
            <input class="ausr-row__level-input" type="number" min="0" max="4" name="system.sprachen.weitere.{{index}}.level" value="{{sprache.level}}">
            <a class="ausr-row__entfernen" data-action="removeLanguage" data-index="{{index}}" title="{{localize 'SCUVANYA.Delete'}}">✕</a>
          </div>
          {{/each}}
        </div>
        <button type="button" class="cc-btn cc-btn--primary" data-action="addLanguage">+ {{localize 'SCUVANYA.Language.Add'}}</button>
      </div>

      {{!-- INVENTAR --}}
      <div class="tab inventar-tab {{#if (eq activeTab 'inventar')}}active{{/if}}">
        {{#each (array "weapon" "armor" "consumable" "equipment") as |type|}}
        <section class="sheet-section">
          <div class="cc-section__head-row">
            <h2 class="cc-section__title">{{localize (concat "SCUVANYA.ItemType." type)}}</h2>
            <button type="button" class="cc-btn" data-action="itemCreate" data-type="{{type}}">+</button>
          </div>
          <div class="ausr-liste">
            {{#each (lookup ../items type) as |item|}}
            <div class="ausr-row" data-item-id="{{item.id}}">
              <img class="ausr-row__img" src="{{item.img}}">
              <a class="ausr-row__name" data-action="itemEdit">{{item.name}}</a>
              <a class="flag-badge {{#if item.system.equipped}}flag-badge--active{{/if}}" data-action="itemToggleEquip">
                {{#if item.system.equipped}}{{localize 'SCUVANYA.Equipped'}}{{else}}{{localize 'SCUVANYA.NotEquipped'}}{{/if}}
              </a>
              <a class="ausr-row__entfernen" data-action="itemDelete" title="{{localize 'SCUVANYA.Delete'}}">✕</a>
            </div>
            {{else}}
            <p class="cc-hint">{{localize (concat "SCUVANYA.ItemType." type)}}: —</p>
            {{/each}}
          </div>
        </section>
        {{/each}}

        <section class="sheet-section">
          <div class="cc-section__head-row">
            <h2 class="cc-section__title">{{localize 'SCUVANYA.Item.race'}}</h2>
            {{#unless items.race}}<button type="button" class="cc-btn" data-action="itemCreate" data-type="race">+</button>{{/unless}}
          </div>
          {{#if items.race}}
          <div class="ausr-liste">
            <div class="ausr-row" data-item-id="{{items.race.id}}">
              <a class="ausr-row__name" data-action="itemEdit">{{items.race.name}}</a>
              <a class="ausr-row__entfernen" data-action="itemDelete" title="{{localize 'SCUVANYA.Delete'}}">✕</a>
            </div>
          </div>
          {{/if}}
        </section>

        <section class="sheet-section">
          <div class="cc-section__head-row">
            <h2 class="cc-section__title">{{localize 'SCUVANYA.Item.profession'}}</h2>
            {{#unless items.profession}}<button type="button" class="cc-btn" data-action="itemCreate" data-type="profession">+</button>{{/unless}}
          </div>
          {{#if items.profession}}
          <div class="ausr-liste">
            <div class="ausr-row" data-item-id="{{items.profession.id}}">
              <a class="ausr-row__name" data-action="itemEdit">{{items.profession.name}}</a>
              <a class="ausr-row__entfernen" data-action="itemDelete" title="{{localize 'SCUVANYA.Delete'}}">✕</a>
            </div>
          </div>
          {{/if}}
        </section>
      </div>

      {{!-- BIOGRAFIE --}}
      <div class="tab biografie-tab {{#if (eq activeTab 'biografie')}}active{{/if}}">
        <h1 class="sheet-title">{{localize 'SCUVANYA.Tab.biografie'}}</h1>

        <div class="cc-row">
          <div class="cc-field">
            <label>{{localize 'SCUVANYA.Body.geschlecht'}}</label>
            <select class="cc-input" name="system.geschlecht">
              <option value="maennlich" {{#if (eq system.geschlecht "maennlich")}}selected{{/if}}>{{localize 'SCUVANYA.Body.maennlich'}}</option>
              <option value="weiblich" {{#if (eq system.geschlecht "weiblich")}}selected{{/if}}>{{localize 'SCUVANYA.Body.weiblich'}}</option>
            </select>
          </div>
          <div class="cc-field">
            <label>{{localize 'SCUVANYA.Body.height'}} (m)</label>
            <input class="cc-input" type="number" step="0.01" min="0" name="system.body.height" value="{{body.height}}">
          </div>
          <div class="cc-field">
            <label>{{localize 'SCUVANYA.Body.weight'}} (kg)</label>
            <input class="cc-input" type="number" step="0.1" min="0" name="system.body.weight" value="{{body.weight}}">
          </div>
          <div class="cc-field">
            <label>{{localize 'SCUVANYA.Body.age'}}</label>
            <input class="cc-input" type="number" min="0" name="system.body.age" value="{{body.age}}">
          </div>
        </div>

        {{#if system.progressionTexts.length}}
        <section class="sheet-section">
          <h2 class="cc-section__title">{{localize 'SCUVANYA.Progression.textTraits'}}</h2>
          <div class="progression-text-list">
            {{#each system.progressionTexts as |entry|}}
            <div class="progression-text-card"><strong>{{entry.name}}:</strong> {{entry.text}}</div>
            {{/each}}
          </div>
        </section>
        {{/if}}

        <section class="sheet-section">
          <textarea class="cc-input biografie-text" name="system.biography" rows="14">{{system.biography}}</textarea>
        </section>
      </div>

    </div>

    <div class="sheet-tab-rail">
      <a class="sheet-tab {{#if (eq activeTab 'attribute')}}sheet-tab--active{{/if}}" data-action="changeTab" data-tab="attribute" title="{{localize 'SCUVANYA.Tab.attribute'}}">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <rect x="5" y="3" width="14" height="18" rx="2"/>
          <line x1="8" y1="8" x2="16" y2="8"/>
          <line x1="8" y1="12" x2="16" y2="12"/>
          <line x1="8" y1="16" x2="13" y2="16"/>
        </svg>
      </a>
      <a class="sheet-tab {{#if (eq activeTab 'talente')}}sheet-tab--active{{/if}}" data-action="changeTab" data-tab="talente" title="{{localize 'SCUVANYA.Tab.talente'}}">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <polygon points="12,2 21,7.5 21,16.5 12,22 3,16.5 3,7.5"/>
          <polyline points="12,2 12,22"/>
          <polyline points="3,7.5 12,12 21,7.5"/>
          <polyline points="3,16.5 12,12 21,16.5"/>
        </svg>
      </a>
