<form class="scuvanya-sheet character-sheet" autocomplete="off">

  <div class="sheet-topbar">
    <div class="sheet-topbar__col sheet-topbar__identity">
      <img class="sheet-topbar__portrait" src="{{actor.img}}" data-action="editImage" data-edit="img" title="{{actor.name}}">
      <input class="sheet-topbar__name" name="name" type="text" value="{{actor.name}}" placeholder="{{localize 'SCUVANYA.Name'}}">
    </div>

    <div class="sheet-topbar__col sheet-topbar__resources">
      <div class="sheet-res sheet-res--lp" title="{{localize 'SCUVANYA.Resource.hp'}}">
        <svg class="sheet-res__icon" viewBox="0 0 24 24" fill="currentColor" stroke="none"><path d="M12 21s-7.5-4.6-10-9.5C0.5 7.8 2.6 4 6.5 4 9 4 11 5.8 12 8c1-2.2 3-4 5.5-4 3.9 0 6 3.8 4.5 7.5C19.5 16.4 12 21 12 21Z"/></svg>
        <span class="sheet-res__label">{{localize 'SCUVANYA.Resource.hpShort'}}</span>
        <div class="sheet-res__bar"><div class="sheet-res__fill sheet-res__fill--lp" style="width: {{percent system.resources.hp.value system.resources.hp.max}}%"></div></div>
        <span class="sheet-res__value">
          <span class="sheet-res__num">{{system.resources.hp.value}}</span>
          <span class="sheet-res__slash">/</span>
          <span class="sheet-res__num sheet-res__num--max">{{system.resources.hp.max}}</span>
        </span>
      </div>

      <div class="sheet-res sheet-res--mana" title="{{localize 'SCUVANYA.Resource.mana'}}">
        <svg class="sheet-res__icon" viewBox="0 0 24 24" fill="currentColor" stroke="none"><path d="M12 2C12 2 5 11 5 15.5A7 7 0 0 0 19 15.5C19 11 12 2 12 2Z"/></svg>
        <span class="sheet-res__label">{{localize 'SCUVANYA.Resource.manaShort'}}</span>
        <div class="sheet-res__bar"><div class="sheet-res__fill sheet-res__fill--mana" style="width: {{percent system.resources.mana.value system.resources.mana.max}}%"></div></div>
        <span class="sheet-res__value">
          <span class="sheet-res__num">{{system.resources.mana.value}}</span>
          <span class="sheet-res__slash">/</span>
          <span class="sheet-res__num sheet-res__num--max">{{system.resources.mana.max}}</span>
        </span>
      </div>

      <div class="sheet-res sheet-res--mg" title="{{localize 'SCUVANYA.Resource.mentalHealth'}}">
        <svg class="sheet-res__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="9"/>
          <path d="M7 9c1.2-1 2-1 3 0s1.8 1 3 0 2-1 3 0"/>
          <path d="M7 12.5c1.2-1 2-1 3 0s1.8 1 3 0 2-1 3 0"/>
          <path d="M7 16c1.2-1 2-1 3 0s1.8 1 3 0 2-1 3 0"/>
        </svg>
        <span class="sheet-res__label">{{localize 'SCUVANYA.Resource.mentalHealthShort'}}</span>
        <div class="sheet-res__bar"><div class="sheet-res__fill sheet-res__fill--mg" style="width: {{percent system.resources.mentalHealth.value system.resources.mentalHealth.max}}%"></div></div>
        <span class="sheet-res__value">
          <span class="sheet-res__num">{{system.resources.mentalHealth.value}}</span>
          <span class="sheet-res__slash">/</span>
          <span class="sheet-res__num sheet-res__num--max">{{system.resources.mentalHealth.max}}</span>
        </span>
      </div>
    </div>

    <div class="sheet-topbar__col sheet-topbar__armor">
      <div class="sheet-armor-stat" title="{{localize 'SCUVANYA.AC'}}">
        <span class="sheet-armor-stat__icon">🛡️</span>
        <span class="sheet-armor-stat__label">{{localize 'SCUVANYA.Short.ac'}}</span>
        <span class="sheet-armor-stat__value">{{system.acEffective}}</span>
      </div>
      <div class="sheet-armor-stat" title="{{localize 'SCUVANYA.Armor.physical'}}">
        <span class="sheet-armor-stat__icon">⚔️</span>
        <span class="sheet-armor-stat__label">{{localize 'SCUVANYA.Short.armorPhysical'}}</span>
        <span class="sheet-armor-stat__value">{{system.armorEffective.physical}}</span>
      </div>
      <div class="sheet-armor-stat" title="{{localize 'SCUVANYA.Armor.magical'}}">
        <span class="sheet-armor-stat__icon">💥</span>
        <span class="sheet-armor-stat__label">{{localize 'SCUVANYA.Short.armorMagical'}}</span>
        <span class="sheet-armor-stat__value">{{system.armorEffective.magical}}</span>
      </div>
    </div>

    <button type="button" class="sheet-topbar__col sheet-topbar__edit" data-action="openCreationWizard">
      <i class="fa-solid fa-hammer"></i>
      <span>{{localize 'SCUVANYA.Sheet.editButton'}}</span>
    </button>
  </div>

  <div class="sheet-folder">
    <div class="sheet-folder__paper sheet-body">

      {{!-- UEBERSICHT --}}
      <div class="tab uebersicht-tab {{#if (eq activeTab 'attribute')}}active{{/if}}">
        <h1 class="sheet-title">{{actor.name}}</h1>
        <div class="sheet-subline">
          {{#if items.race}}<span>{{items.race.name}}{{#if subraceName}} ({{subraceName}}){{/if}}</span>{{/if}}
          {{#if items.profession}}<span>{{items.profession.name}}</span>{{/if}}
          <span>{{localize (concat "SCUVANYA.Body." system.geschlecht)}}</span>
          {{#if body.age}}<span>{{body.age}} {{localize 'SCUVANYA.Body.age'}}</span>{{/if}}
          {{#if body.height}}<span>{{body.height}} m</span>{{/if}}
          {{#if body.weight}}<span>{{body.weight}} kg</span>{{/if}}
        </div>

        <section class="sheet-section">
          <h2 class="cc-section__title">{{localize 'SCUVANYA.Section.attribute'}}</h2>
          <div class="attr-tile-container">
            <div class="attr-tile-row">
              {{#each attributes as |attr|}}
              <div class="attr-tile" data-action="rollAttribute" data-key="{{attr.key}}" title="{{localize 'SCUVANYA.Roll'}}">
                {{#if attr.hasItemBonus}}<span class="item-bonus-dot" title="{{localize 'SCUVANYA.Hint.ItemBonusIncluded'}}"></span>{{/if}}
                <i class="fa-solid {{attr.icon}} attr-tile__icon"></i>
                <span class="attr-tile__abbr">{{attr.abbr}}</span>
                <span class="attr-tile__name">{{attr.label}}</span>
                <span class="attr-tile__value">{{attr.effectiveValue}}</span>
                <span class="attr-tile__mod">{{attr.modDisplay}}</span>
              </div>
              {{/each}}
            </div>
          </div>
        </section>

        <section class="sheet-section">
          <h2 class="cc-section__title">{{localize 'SCUVANYA.Progression.textTraits'}}</h2>
          {{#if system.progressionTexts.length}}
          <div class="progression-text-list">
            {{#each system.progressionTexts as |entry|}}
            <div class="progression-text-card"><strong>{{entry.name}}:</strong> {{entry.text}}</div>
            {{/each}}
          </div>
          {{else}}
          <p class="cc-hint">{{localize 'SCUVANYA.Progression.textTraitsNone'}}</p>
          {{/if}}
        </section>

        <section class="sheet-section">
          <h2 class="cc-section__title">{{localize 'SCUVANYA.Section.resistenzen'}}</h2>
          {{#if resistanceChips.length}}
          <div class="cc-chip-row">
            {{#each resistanceChips as |chip|}}
            <span class="cc-chip uebersicht-resistenz-chip uebersicht-resistenz-chip--{{chip.typ}}">{{chip.name}}: {{chip.label}}</span>
            {{/each}}
          </div>
          {{else}}
          <p class="cc-hint">{{localize 'SCUVANYA.Resistance.none'}}</p>
          {{/if}}
        </section>

        {{#if weitereSprachen.length}}
        <section class="sheet-section">
          <h2 class="cc-section__title">{{localize 'SCUVANYA.Section.sprachenBekannt'}}</h2>
          <div class="cc-chip-row">
            <span class="cc-chip">{{localize 'SCUVANYA.Language.Gemeinsprache'}} · {{gemeinsprache.level}}</span>
            {{#each weitereSprachen as |sprache|}}
            <span class="cc-chip">{{sprache.name}} · {{sprache.level}}</span>
            {{/each}}
          </div>
        </section>
        {{/if}}

        <section class="sheet-section">
          <h2 class="cc-section__title">{{localize 'SCUVANYA.Section.biografie'}}</h2>
          <textarea class="cc-input biografie-text" name="system.biography" rows="8">{{system.biography}}</textarea>
        </section>
      </div>

      {{!-- TALENTE --}}
      <div class="tab talente-tab {{#if (eq activeTab 'talente')}}active{{/if}}">
        <h1 class="sheet-title">{{localize 'SCUVANYA.Tab.talente'}}</h1>
        <p class="sheet-hint">{{localize 'SCUVANYA.Hint.EditInCreator'}}</p>

        <div class="talente-liste">
          <div class="cc-category-pair">
            <div class="cc-category">
              <div class="cc-category__header"><span>{{localize 'SCUVANYA.Section.attribute'}}</span></div>
              <div class="attr-mini-grid">
                {{#each attributes as |attr|}}
                <div class="attr-mini" data-action="rollAttribute" data-key="{{attr.key}}" title="{{attr.label}}">
                  {{#if attr.hasItemBonus}}<span class="item-bonus-dot" style="top:-2px;right:-2px;width:7px;height:7px;"></span>{{/if}}
                  <i class="fa-solid {{attr.icon}} attr-mini__icon"></i>
                  <span class="attr-mini__abbr">{{attr.abbr}}</span>
                  <span class="attr-mini__value">{{attr.effectiveValue}}</span>
                </div>
                {{/each}}
              </div>
            </div>
            {{> "systems/scuvanya/templates/actor/parts/skill-category.hbs" title=(localize 'SCUVANYA.Category.koerperlich') skills=koerperlich rollAction="rollPhysicalSkill" bonusLabel=koerperlichBonusLabel}}
          </div>

          <div class="cc-category-pair">
            {{> "systems/scuvanya/templates/actor/parts/skill-category.hbs" title=(localize 'SCUVANYA.Category.sozialPositiv') skills=sozialPositiv rollAction="rollSocialSkill" rollDataName="polarity" rollDataValue="positiv" bonusLabel=sozialBonusLabel}}
            {{> "systems/scuvanya/templates/actor/parts/skill-category.hbs" title=(localize 'SCUVANYA.Category.sozialNegativ') skills=sozialNegativ rollAction="rollSocialSkill" rollDataName="polarity" rollDataValue="negativ" bonusLabel=sozialBonusLabel}}
          </div>

          <div class="cc-category-pair">
            {{> "systems/scuvanya/templates/actor/parts/skill-category.hbs" title=(localize 'SCUVANYA.Category.wissenschaftenNatur') skills=wissenschaftenNatur rollAction="rollScienceSkill" rollDataName="branch" rollDataValue="natur" bonusLabel=wissenschaftBonusLabel}}
            {{> "systems/scuvanya/templates/actor/parts/skill-category.hbs" title=(localize 'SCUVANYA.Category.wissenschaftenSozial') skills=wissenschaftenSozial rollAction="rollScienceSkill" rollDataName="branch" rollDataValue="sozial" bonusLabel=wissenschaftBonusLabel}}
          </div>

          <div class="cc-category-pair">
            {{> "systems/scuvanya/templates/actor/parts/skill-category.hbs" title=(localize 'SCUVANYA.Category.sonder') skills=sonder rollAction="rollSonderSkill" bonusLabel=sonderBonusLabel}}
            {{> "systems/scuvanya/templates/actor/parts/tiered-category.hbs" title=(localize 'SCUVANYA.Category.handwerk') skills=handwerk rollAction="rollHandwerkSkill"}}
          </div>

          <div class="cc-category-pair">
            <div class="cc-category">
              <div class="cc-category__header"><span>{{localize 'SCUVANYA.Category.extra'}}</span></div>
              <div class="cc-category__body">
                {{#each extra as |skill|}}
                <div class="talent-row talent-row--extra">
                  <span class="talent-row__name">{{skill.label}}</span>
                  <span class="talent-row__stat">{{#if skill.known}}✓{{else}}—{{/if}}</span>
                </div>
                {{/each}}
              </div>
            </div>
            {{> "systems/scuvanya/templates/actor/parts/tiered-category.hbs" title=(localize 'SCUVANYA.Category.spezial') skills=spezial rollAction="rollSpezialSkill"}}
          </div>
        </div>
      </div>

      {{!-- DISZIPLINEN --}}
      <div class="tab disziplinen-tab {{#if (eq activeTab 'kampf')}}active{{/if}}">
        <h1 class="sheet-title">{{localize 'SCUVANYA.Tab.kampf'}}</h1>

        <section class="sheet-section">
          <h2 class="cc-section__title">{{localize 'SCUVANYA.Category.kampfdisziplinen'}}</h2>
          <div class="disziplin-grid">
            {{#each kampfDisziplinen as |d|}}
            <div class="disziplin-tile" style="--glow-level: {{d.level}};" data-action="rollDiscipline" data-kind="kampf" data-key="{{d.key}}" title="{{localize 'SCUVANYA.Roll'}}">
              {{#if d.hasItemBonus}}<span class="item-bonus-dot" title="{{localize 'SCUVANYA.Hint.ItemBonusIncluded'}}"></span>{{/if}}
              {{#if d.img}}<img class="disziplin-tile__img" src="{{d.img}}">{{else}}<div class="disziplin-tile__img disziplin-tile__img--placeholder"></div>{{/if}}
              <span class="disziplin-tile__name">{{d.label}}</span>
              <span class="disziplin-tile__level">{{d.level}}</span>
            </div>
            {{/each}}
          </div>
        </section>

        <section class="sheet-section">
          <h2 class="cc-section__title">{{localize 'SCUVANYA.Category.magiedisziplinen'}}</h2>
          <div class="disziplin-grid">
            {{#each magieDisziplinen as |d|}}
            <div class="disziplin-tile" style="--glow-level: {{d.level}};" data-action="rollDiscipline" data-kind="magie" data-key="{{d.key}}" title="{{localize 'SCUVANYA.Roll'}}">
              {{#if d.hasItemBonus}}<span class="item-bonus-dot" title="{{localize 'SCUVANYA.Hint.ItemBonusIncluded'}}"></span>{{/if}}
              {{#if d.img}}<img class="disziplin-tile__img" src="{{d.img}}">{{else}}<div class="disziplin-tile__img disziplin-tile__img--placeholder"></div>{{/if}}
              <span class="disziplin-tile__name">{{d.label}}</span>
              <span class="disziplin-tile__level">{{d.level}}</span>
            </div>
            {{/each}}
          </div>
        </section>
      </div>

      {{!-- AKTIONEN --}}
      <div class="tab aktionen-tab {{#if (eq activeTab 'aktionen')}}active{{/if}}">
        <h1 class="sheet-title">{{localize 'SCUVANYA.Tab.aktionen'}}</h1>
        <p class="cc-hint">{{localize 'SCUVANYA.Hint.AktionenComingSoon'}}</p>
      </div>

      {{!-- INVENTAR --}}
      <div class="tab inventar-tab {{#if (eq activeTab 'inventar')}}active{{/if}}">

        <section class="sheet-section">
          <h2 class="cc-section__title">{{localize 'SCUVANYA.Section.ausgeruestet'}}</h2>
          <div class="slot-bar">
            {{#each slotsRuestung as |slot|}}
            {{> "systems/scuvanya/templates/actor/parts/slot-chip.hbs" slot=slot}}
            {{/each}}
          </div>
          <div class="slot-bar">
            {{#each slotsSchmuck as |slot|}}
            {{> "systems/scuvanya/templates/actor/parts/slot-chip.hbs" slot=slot}}
            {{/each}}
          </div>
          <div class="slot-bar">
            {{#each slotsHand as |slot|}}
            {{> "systems/scuvanya/templates/actor/parts/slot-chip.hbs" slot=slot}}
            {{/each}}
          </div>
        </section>

        <section class="sheet-section">
          <div class="cc-section__head-row">
            <h2 class="cc-section__title">{{localize 'SCUVANYA.Section.inventarListe'}}</h2>
            <div class="inventory-create">
              {{#each (array "weapon" "armor" "consumable" "equipment") as |type|}}
              <button type="button" class="cc-btn" data-action="itemCreate" data-type="{{type}}">+ {{localize (concat "SCUVANYA.ItemType." type)}}</button>
              {{/each}}
            </div>
          </div>

          <div class="inventory-toolbar">
            <input type="text" class="cc-input inventory-search" placeholder="{{localize 'SCUVANYA.Inventory.Search'}}">
            <div class="inventory-sort">
              <a class="cc-chip inventory-sort-btn" data-sort="name">{{localize 'SCUVANYA.Inventory.SortName'}}</a>
              <a class="cc-chip inventory-sort-btn" data-sort="type">{{localize 'SCUVANYA.Inventory.SortType'}}</a>
            </div>
          </div>

          {{#if allFlags.length}}
          <div class="cc-chip-row inventory-flag-filters">
            {{#each allFlags as |flag|}}
            <a class="cc-chip inventory-flag-filter" data-flag="{{flag}}">{{flag}}</a>
            {{/each}}
          </div>
          {{/if}}

          <div class="ausr-liste inventory-list">
            {{#each inventoryItems as |item|}}
            <div class="ausr-row inventory-row" data-item-id="{{item.id}}" data-name="{{item.name}}" data-type="{{item.typeLabel}}" data-flags="{{item.flagsJoined}}">
              <img class="ausr-row__img" src="{{item.img}}">
              <a class="ausr-row__name" data-action="itemEdit">{{item.name}}</a>
              <span class="ausr-row__type">{{item.typeLabel}}</span>
              <span class="flag-badge-row">
                {{#each item.flags as |flag|}}<span class="flag-badge">{{flag}}</span>{{/each}}
                {{#if item.equippedSlotLabel}}<span class="flag-badge flag-badge--active">{{item.equippedSlotLabel}}</span>{{/if}}
              </span>
              <a class="ausr-row__entfernen" data-action="itemDelete" title="{{localize 'SCUVANYA.Delete'}}">✕</a>
            </div>
            {{else}}
            <p class="cc-hint">{{localize 'SCUVANYA.Inventory.Empty'}}</p>
            {{/each}}
          </div>
        </section>

        <section class="sheet-section">
          <div class="cc-section__head-row">
            <h2 class="cc-section__title">{{localize 'SCUVANYA.Item.race'}}</h2>
            {{#unless items.race}}<button type="button" class="cc-btn" data-action="itemCreate" data-type="race">+</button>{{/unless}}
          </div>
          {{#if items.race}}
          <div class="ausr-liste">
            <div class="ausr-row" data-item-id="{{items.race.id}}">
              <a class="ausr-row__name" data-action="itemEdit">{{items.race.name}}</a>
              <a class="ausr-row__entfernen" data-action="itemDelete" title="{{localize 'SCUVANYA.Delete'}}">✕</a>
            </div>
          </div>
          {{/if}}
        </section>

        <section class="sheet-section">
          <div class="cc-section__head-row">
            <h2 class="cc-section__title">{{localize 'SCUVANYA.Item.profession'}}</h2>
            {{#unless items.profession}}<button type="button" class="cc-btn" data-action="itemCreate" data-type="profession">+</button>{{/unless}}
          </div>
          {{#if items.profession}}
          <div class="ausr-liste">
            <div class="ausr-row" data-item-id="{{items.profession.id}}">
              <a class="ausr-row__name" data-action="itemEdit">{{items.profession.name}}</a>
              <a class="ausr-row__entfernen" data-action="itemDelete" title="{{localize 'SCUVANYA.Delete'}}">✕</a>
            </div>
          </div>
          {{/if}}
        </section>
      </div>

    </div>

    <div class="sheet-tab-rail">
      <a class="sheet-tab {{#if (eq activeTab 'attribute')}}sheet-tab--active{{/if}}" data-action="changeTab" data-tab="attribute" title="{{localize 'SCUVANYA.Tab.attribute'}}">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <rect x="5" y="3" width="14" height="18" rx="2"/>
          <line x1="8" y1="8" x2="16" y2="8"/>
          <line x1="8" y1="12" x2="16" y2="12"/>
          <line x1="8" y1="16" x2="13" y2="16"/>
        </svg>
      </a>
      <a class="sheet-tab {{#if (eq activeTab 'talente')}}sheet-tab--active{{/if}}" data-action="changeTab" data-tab="talente" title="{{localize 'SCUVANYA.Tab.talente'}}">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <polygon points="12,2 21,7.5 21,16.5 12,22 3,16.5 3,7.5"/>
          <polyline points="12,2 12,22"/>
          <polyline points="3,7.5 12,12 21,7.5"/>
          <polyline points="3,16.5 12,12 21,16.5"/>
        </svg>
      </a>
      <a class="sheet-tab {{#if (eq activeTab 'kampf')}}sheet-tab--active{{/if}}" data-action="changeTab" data-tab="kampf" title="{{localize 'SCUVANYA.Tab.kampf'}}">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <polygon points="13,2 4,14 11,14 9,22 20,9 13,9"/>
        </svg>
      </a>
      <a class="sheet-tab {{#if (eq activeTab 'aktionen')}}sheet-tab--active{{/if}}" data-action="changeTab" data-tab="aktionen" title="{{localize 'SCUVANYA.Tab.aktionen'}}">
        <i class="fa-solid fa-hand-fist"></i>
      </a>
      <a class="sheet-tab {{#if (eq activeTab 'inventar')}}sheet-tab--active{{/if}}" data-action="changeTab" data-tab="inventar" title="{{localize 'SCUVANYA.Tab.inventar'}}">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 2 L20 5 V11 C20 16 16.5 20 12 22 C7.5 20 4 16 4 11 V5 Z"/>
        </svg>
      </a>
    </div>
  </div>
</form>
