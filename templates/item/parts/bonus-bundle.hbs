{{!--
  prefix/bundle/config sind Hash-Argumente des Partial-Aufrufs, KEINE Block-Parameter --
  ohne den {{#with this as |root|}}-Trick bräuchte fast jede Referenz hier drin eine
  unterschiedliche Anzahl "../" je nach Verschachtelungstiefe (each in each in each).
  "root" als Block-Parameter ist dagegen in JEDER Tiefe ohne "../" erreichbar.
--}}
{{#with this as |root|}}
<div class="bonus-bundle" data-prefix="{{root.prefix}}">
  <h4>{{localize 'SCUVANYA.Progression.eigenschaften'}}
    <button type="button" data-action="addEigenschaft" data-prefix="{{root.prefix}}">+</button>
  </h4>

  {{#each root.bundle.eigenschaften as |eig eigIndex|}}
  <details class="eigenschaft-section" open>
    <summary>
      <input type="text" name="{{root.prefix}}.eigenschaften.{{eigIndex}}.name" value="{{eig.name}}" placeholder="{{localize 'SCUVANYA.Progression.eigenschaftName'}}">
      <a data-action="removeEigenschaft" data-prefix="{{root.prefix}}" data-eigenschaft-index="{{eigIndex}}">{{localize 'SCUVANYA.Delete'}}</a>
    </summary>

    <textarea class="eigenschaft-description" name="{{root.prefix}}.eigenschaften.{{eigIndex}}.description" rows="2" placeholder="{{localize 'SCUVANYA.Progression.eigenschaftDescription'}}">{{eig.description}}</textarea>

    {{#each eig.boni as |bonus bonusIndex|}}
    <div class="bonus-row" data-eigenschaft-index="{{eigIndex}}" data-bonus-index="{{bonusIndex}}">
      <div class="bonus-fields">
        <select name="{{root.prefix}}.eigenschaften.{{eigIndex}}.boni.{{bonusIndex}}.kind">
          {{#each root.config.bonusKinds as |kind|}}
          <option value="{{kind}}" {{#if (eq kind bonus.kind)}}selected{{/if}}>{{localize (concat "SCUVANYA.Progression.bonusKind." kind)}}</option>
          {{/each}}
        </select>

        {{#if (eq bonus.kind "fixed")}}
        <input type="text" name="{{root.prefix}}.eigenschaften.{{eigIndex}}.boni.{{bonusIndex}}.path" value="{{bonus.path}}" placeholder="{{localize 'SCUVANYA.Progression.bonusPath'}}">
        <input type="number" name="{{root.prefix}}.eigenschaften.{{eigIndex}}.boni.{{bonusIndex}}.amount" value="{{bonus.amount}}" title="{{localize 'SCUVANYA.Progression.bonusAmount'}}">
        {{/if}}

        {{#if (eq bonus.kind "choice")}}
        <input type="number" name="{{root.prefix}}.eigenschaften.{{eigIndex}}.boni.{{bonusIndex}}.amount" value="{{bonus.amount}}" title="{{localize 'SCUVANYA.Progression.bonusAmount'}}">
        {{/if}}

        {{#if (eq bonus.kind "distribute")}}
        <input type="number" name="{{root.prefix}}.eigenschaften.{{eigIndex}}.boni.{{bonusIndex}}.amount" value="{{bonus.amount}}" title="{{localize 'SCUVANYA.Progression.bonusAmount'}}">
        <input type="number" min="0" name="{{root.prefix}}.eigenschaften.{{eigIndex}}.boni.{{bonusIndex}}.perOptionMax" value="{{bonus.perOptionMax}}" title="{{localize 'SCUVANYA.Progression.bonusPerOptionMax'}}">
        {{/if}}

        {{#if (eq bonus.kind "text")}}
        <input type="text" name="{{root.prefix}}.eigenschaften.{{eigIndex}}.boni.{{bonusIndex}}.text" value="{{bonus.text}}" placeholder="{{localize 'SCUVANYA.Progression.bonusText'}}">
        {{/if}}

        <a data-action="removeBonus" data-prefix="{{root.prefix}}" data-eigenschaft-index="{{eigIndex}}" data-bonus-index="{{bonusIndex}}">{{localize 'SCUVANYA.Delete'}}</a>
      </div>

      {{#if (or (eq bonus.kind "choice") (eq bonus.kind "distribute"))}}
      <div class="bonus-key-row">
        <label>{{localize 'SCUVANYA.Progression.choiceKey'}}</label>
        <input type="text" name="{{root.prefix}}.eigenschaften.{{eigIndex}}.boni.{{bonusIndex}}.key" value="{{bonus.key}}">
      </div>
      <div class="bonus-options">
        <span class="hint">{{localize 'SCUVANYA.Progression.bonusOptions'}}:</span>
        {{#each bonus.options as |option optionIndex|}}
        <span class="choice-option" data-option-index="{{optionIndex}}">
          <input type="text" name="{{root.prefix}}.eigenschaften.{{eigIndex}}.boni.{{bonusIndex}}.options.{{optionIndex}}" value="{{option}}">
          <a data-action="removeBonusOption" data-prefix="{{root.prefix}}" data-eigenschaft-index="{{eigIndex}}" data-bonus-index="{{bonusIndex}}" data-option-index="{{optionIndex}}">×</a>
        </span>
        {{/each}}
        <button type="button" data-action="addBonusOption" data-prefix="{{root.prefix}}" data-eigenschaft-index="{{eigIndex}}" data-bonus-index="{{bonusIndex}}">+ {{localize 'SCUVANYA.Progression.choiceOption'}}</button>
      </div>
      {{/if}}
    </div>
    {{/each}}
    <button type="button" data-action="addBonus" data-prefix="{{root.prefix}}" data-eigenschaft-index="{{eigIndex}}">+ {{localize 'SCUVANYA.Progression.boni'}}</button>
  </details>
  {{/each}}
</div>
{{/with}}
