<form class="scuvanya-sheet item-sheet" autocomplete="off">
  <header class="sheet-header">
    <img class="profile-img" src="{{item.img}}" data-action="editImage" data-edit="img" title="{{item.name}}">
    <div class="header-fields">
      <input name="name" type="text" value="{{item.name}}" placeholder="{{localize 'SCUVANYA.Name'}}">
      <span class="item-type">{{localize (concat "SCUVANYA.ItemType." item.type)}}</span>
    </div>
  </header>

  <section class="sheet-body">

    {{#if (eq item.type "weapon")}}
    <div class="form-group">
      <label>{{localize 'SCUVANYA.Weapon.damageFormula'}}</label>
      <input type="text" name="system.damageFormula" value="{{system.damageFormula}}">
    </div>
    <div class="form-group">
      <label>{{localize 'SCUVANYA.Weapon.damageType'}}</label>
      <select name="system.damageType">
        {{#each config.damageTypes as |cfg key|}}
        <option value="{{key}}" {{#if (eq key ../system.damageType)}}selected{{/if}}>{{localize cfg.label}}</option>
        {{/each}}
      </select>
    </div>
    <div class="form-group">
      <label><input type="checkbox" name="system.ranged" {{#if system.ranged}}checked{{/if}}> {{localize 'SCUVANYA.Weapon.ranged'}}</label>
    </div>
    <div class="form-group">
      <label>{{localize 'SCUVANYA.Weapon.discipline'}}</label>
      <input type="text" name="system.discipline" value="{{system.discipline}}">
    </div>
    <div class="form-group">
      <label><input type="checkbox" name="system.equipped" {{#if system.equipped}}checked{{/if}}> {{localize 'SCUVANYA.Equipped'}}</label>
    </div>
    {{/if}}

    {{#if (eq item.type "armor")}}
    <div class="form-group">
      <label>{{localize 'SCUVANYA.Armor.armorType'}}</label>
      <select name="system.armorType">
        <option value="physical" {{#if (eq system.armorType "physical")}}selected{{/if}}>{{localize 'SCUVANYA.Armor.physical'}}</option>
        <option value="magical" {{#if (eq system.armorType "magical")}}selected{{/if}}>{{localize 'SCUVANYA.Armor.magical'}}</option>
        <option value="both" {{#if (eq system.armorType "both")}}selected{{/if}}>{{localize 'SCUVANYA.Armor.both'}}</option>
      </select>
    </div>
    <div class="form-group">
      <label>{{localize 'SCUVANYA.Value'}}</label>
      <input type="number" name="system.value" value="{{system.value}}">
    </div>
    <div class="form-group">
      <label>{{localize 'SCUVANYA.Armor.slot'}}</label>
      <input type="text" name="system.slot" value="{{system.slot}}">
    </div>
    <div class="form-group">
      <label><input type="checkbox" name="system.equipped" {{#if system.equipped}}checked{{/if}}> {{localize 'SCUVANYA.Equipped'}}</label>
    </div>
    {{/if}}

    {{#if (eq item.type "consumable")}}
    <div class="form-group">
      <label>{{localize 'SCUVANYA.Quantity'}}</label>
      <input type="number" name="system.quantity" value="{{system.quantity}}">
    </div>
    <div class="form-group">
      <label><input type="checkbox" name="system.consumeOnUse" {{#if system.consumeOnUse}}checked{{/if}}> {{localize 'SCUVANYA.Consumable.consumeOnUse'}}</label>
    </div>
    {{/if}}

    {{#if (eq item.type "equipment")}}
    <div class="form-group">
      <label>{{localize 'SCUVANYA.Quantity'}}</label>
      <input type="number" name="system.quantity" value="{{system.quantity}}">
    </div>
    <div class="form-group">
      <label>{{localize 'SCUVANYA.Equipment.weight'}}</label>
      <input type="number" name="system.weight" value="{{system.weight}}">
    </div>
    {{/if}}

    {{#if (eq item.type "profession")}}
    {{> "systems/scuvanya/templates/item/parts/bonus-bundle.hbs" prefix="system" bundle=system config=config}}
    {{/if}}

    {{#if (eq item.type "race")}}
    <h3>{{localize 'SCUVANYA.Race.genderImages'}}</h3>
    <div class="gender-image-grid">
      <div class="gender-image-group">
        <label>{{localize 'SCUVANYA.Body.maennlich'}}</label>
        <img class="gender-image-preview" src="{{system.imageMaennlich}}" data-action="editImage" data-edit="system.imageMaennlich" title="{{localize 'SCUVANYA.Body.maennlich'}}">
      </div>
      <div class="gender-image-group">
        <label>{{localize 'SCUVANYA.Body.weiblich'}}</label>
        <img class="gender-image-preview" src="{{system.imageWeiblich}}" data-action="editImage" data-edit="system.imageWeiblich" title="{{localize 'SCUVANYA.Body.weiblich'}}">
      </div>
    </div>

    <h3>{{localize 'SCUVANYA.Progression.bodyRanges'}}</h3>
    <p class="hint">{{localize 'SCUVANYA.Progression.bodyRangesHint'}}</p>

    <h4>{{localize 'SCUVANYA.Body.maennlich'}}</h4>
    <div class="attribute-bonus-grid body-range-grid">
      <label>{{localize 'SCUVANYA.Body.heightMin'}} (m)
        <input type="number" step="0.01" min="0" name="system.body.maennlich.heightMin" value="{{system.body.maennlich.heightMin}}">
      </label>
      <label>{{localize 'SCUVANYA.Body.heightMax'}} (m)
        <input type="number" step="0.01" min="0" name="system.body.maennlich.heightMax" value="{{system.body.maennlich.heightMax}}">
      </label>
      <label>{{localize 'SCUVANYA.Body.weightMin'}} (kg)
        <input type="number" step="0.1" min="0" name="system.body.maennlich.weightMin" value="{{system.body.maennlich.weightMin}}">
      </label>
      <label>{{localize 'SCUVANYA.Body.weightMax'}} (kg)
        <input type="number" step="0.1" min="0" name="system.body.maennlich.weightMax" value="{{system.body.maennlich.weightMax}}">
      </label>
      <label>{{localize 'SCUVANYA.Body.muendigkeitsalter'}}
        <input type="number" min="0" name="system.body.maennlich.muendigkeitsalter" value="{{system.body.maennlich.muendigkeitsalter}}">
      </label>
      <label>{{localize 'SCUVANYA.Body.erwachsenenalter'}}
        <input type="number" min="0" name="system.body.maennlich.erwachsenenalter" value="{{system.body.maennlich.erwachsenenalter}}">
      </label>
      <label>{{localize 'SCUVANYA.Body.lebenserwartung'}}
        <input type="number" min="0" name="system.body.maennlich.lebenserwartung" value="{{system.body.maennlich.lebenserwartung}}">
      </label>
    </div>

    <h4>{{localize 'SCUVANYA.Body.weiblich'}}</h4>
    <div class="attribute-bonus-grid body-range-grid">
      <label>{{localize 'SCUVANYA.Body.heightMin'}} (m)
        <input type="number" step="0.01" min="0" name="system.body.weiblich.heightMin" value="{{system.body.weiblich.heightMin}}">
      </label>
      <label>{{localize 'SCUVANYA.Body.heightMax'}} (m)
        <input type="number" step="0.01" min="0" name="system.body.weiblich.heightMax" value="{{system.body.weiblich.heightMax}}">
      </label>
      <label>{{localize 'SCUVANYA.Body.weightMin'}} (kg)
        <input type="number" step="0.1" min="0" name="system.body.weiblich.weightMin" value="{{system.body.weiblich.weightMin}}">
      </label>
      <label>{{localize 'SCUVANYA.Body.weightMax'}} (kg)
        <input type="number" step="0.1" min="0" name="system.body.weiblich.weightMax" value="{{system.body.weiblich.weightMax}}">
      </label>
      <label>{{localize 'SCUVANYA.Body.muendigkeitsalter'}}
        <input type="number" min="0" name="system.body.weiblich.muendigkeitsalter" value="{{system.body.weiblich.muendigkeitsalter}}">
      </label>
      <label>{{localize 'SCUVANYA.Body.erwachsenenalter'}}
        <input type="number" min="0" name="system.body.weiblich.erwachsenenalter" value="{{system.body.weiblich.erwachsenenalter}}">
      </label>
      <label>{{localize 'SCUVANYA.Body.lebenserwartung'}}
        <input type="number" min="0" name="system.body.weiblich.lebenserwartung" value="{{system.body.weiblich.lebenserwartung}}">
      </label>
    </div>

    <details class="bonus-bundle-section" open>
      <summary>{{localize 'SCUVANYA.Race.base'}}</summary>
      {{> "systems/scuvanya/templates/item/parts/bonus-bundle.hbs" prefix="system.base" bundle=system.base config=config}}
    </details>

    <details class="bonus-bundle-section">
      <summary>{{localize 'SCUVANYA.Race.maennlich'}}</summary>
      {{> "systems/scuvanya/templates/item/parts/bonus-bundle.hbs" prefix="system.maennlich" bundle=system.maennlich config=config}}
    </details>

    <details class="bonus-bundle-section">
      <summary>{{localize 'SCUVANYA.Race.weiblich'}}</summary>
      {{> "systems/scuvanya/templates/item/parts/bonus-bundle.hbs" prefix="system.weiblich" bundle=system.weiblich config=config}}
    </details>

    <h3>{{localize 'SCUVANYA.Race.subraces'}}
      <button type="button" data-action="addSubrace">+</button>
    </h3>
    <p class="hint">{{localize 'SCUVANYA.Race.subracesHint'}}</p>
    {{#each system.subraces as |subrace subraceIndex|}}
    <details class="bonus-bundle-section subrace-section" data-subrace-index="{{subraceIndex}}">
      <summary>
        <input type="text" name="system.subraces.{{subraceIndex}}.key" value="{{subrace.key}}" placeholder="{{localize 'SCUVANYA.Race.subraceKey'}}">
        <input type="text" name="system.subraces.{{subraceIndex}}.name" value="{{subrace.name}}" placeholder="{{localize 'SCUVANYA.Race.subraceName'}}">
        <a data-action="removeSubrace" data-subrace-index="{{subraceIndex}}">{{localize 'SCUVANYA.Delete'}}</a>
      </summary>
      {{> "systems/scuvanya/templates/item/parts/bonus-bundle.hbs" prefix=(concat "system.subraces." subraceIndex ".bonuses") bundle=subrace.bonuses config=../config}}
    </details>
    {{/each}}
    {{/if}}

    <h3>{{localize 'SCUVANYA.Description'}}</h3>
    <textarea name="system.description" rows="8">{{system.description}}</textarea>
  </section>
</form>
